# PropTx (TRREB portal) credentials
# Note: PropTx requires SMS-based 2FA — the code must be entered manually at login
PROPTX_USERNAME=your_proptx_username
PROPTX_PASSWORD=your_proptx_password

# SkySlope Forms credentials
SKYSLOPE_EMAIL=your_skyslope_email
SKYSLOPE_PASSWORD=your_skyslope_password

# SkySlope create-file fallbacks used when the property CSV does not already
# contain these values.
SKYSLOPE_CLIENT_EMAIL=listing.client@example.com
SKYSLOPE_DEFAULT_COUNTY=Toronto

# Optional browser profile override. By default, browser data is stored under
# artifacts/browser-data/default-profile.
# BROWSER_PROFILE_DIR=artifacts/browser-data/verify-run
